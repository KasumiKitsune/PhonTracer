{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "PhonRec 主窗口所需的最小权限",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "dialog:default",
    "fs:allow-write-file",
    "allow-app-commands",
    {
      "identifier": "opener:allow-open-url",
      "allow": [
        {
          "url": "https://github.com/KasumiKitsune/PhonTracer/releases/*"
        }
      ]
    }
  ]
}
